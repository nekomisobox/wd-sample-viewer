{
  "manifest_version": 3,
  "name": "WD Tag Sample",
  "version": "0.2.0",
  "description": "Extract WD14 tags from an image and generate a txt2img sample with Forge/ReForge or ComfyUI.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "WD Tag Sample"
  }
}
